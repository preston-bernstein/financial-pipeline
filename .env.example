# Infrastructure config — copy to .env and fill in real values
# Financial domain config lives in pipeline.config.toml (see pipeline.config.example.toml)

# Database — password is read from secrets/postgres_password.txt at runtime (never in this URL)
DATABASE_URL=postgresql://pipeline@postgres:5432/pipeline

# MCP server (3101 avoids collision with Loki's default 3100)
MCP_PORT=3101

# Grafana
GRAFANA_PORT=3200
# Grafana admin password is read from secrets/grafana_password.txt via GF_SECURITY_ADMIN_PASSWORD__FILE

# Loki
LOKI_URL=http://loki:3100

# ntfy
NTFY_URL=http://ntfy:80
NTFY_TOPIC=financial-pipeline

# Ollama broker (desktop) — always use broker, never raw :11434
JOURNAL_BROKER_URL=http://10.0.0.243:11435   # interactive port — journal narrative generation
OLLAMA_BROKER_URL=http://10.0.0.243:11436    # batch port — transaction enrichment
JOURNAL_MODEL=qwen2.5
ENRICHER_MODEL=qwen2.5:3b              # L1: fast local batch pass
ENRICHER_MODEL_L2=qwen2.5:7b          # L2: careful single-tx, local
ENRICHER_MODEL_L3=Qwen/Qwen2.5-72B-Instruct  # L3: RunPod 72B, only for still-"other" after L2
# RunPod serverless — deploy vLLM worker with Qwen2.5-72B, get endpoint ID from RunPod dashboard
RUNPOD_BASE_URL=https://api.runpod.ai/v2/<endpoint_id>/openai/v1
RUNPOD_API_KEY=

# Plaid credentials are read from secrets/plaid_credentials.json at runtime
# Fill in client_id, secret, environment (sandbox|production), and access_tokens after completing Plaid Link
